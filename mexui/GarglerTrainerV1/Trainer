function gt_showMessage(text) {
    try {
        natives.printStringWithLiteralStringNow('STRING', text, 3000, true);
    } catch (e) {
        // ignore
    }
}

function gt_getPosInFrontOfPlayer(distance) {
    try {
        if (!localPlayer || !localPlayer.position) return null;
        var pos     = localPlayer.position;
        var heading = localPlayer.heading;
        var x = pos.x + distance * Math.cos(heading);
        var y = pos.y + distance * Math.sin(heading);
        var z = pos.z;
        return new Vec3(x, y, z);
    } catch (e) {
        gt_showMessage('Failed to calculate front position');
        return null;
    }
}

function gt_getPlayerVehicle(attempts, maxAttempts, delay, cb) {
    if (attempts > maxAttempts) {
        try {
            if (localPlayer && !natives.isCharInAnyCar(localPlayer)) {
                gt_showMessage('Not in a vehicle');
            } else {
                gt_showMessage('Cannot detect vehicle');
            }
        } catch (e) {}
        cb(null);
        return;
    }

    try {
        if (!localPlayer) {
            setTimeout(function() {
                gt_getPlayerVehicle(attempts + 1, maxAttempts, delay, cb);
            }, delay);
            return;
        }

        if (localPlayer.vehicle && natives.doesVehicleExist(localPlayer.vehicle) && natives.isCharInAnyCar(localPlayer)) {
            cb(localPlayer.vehicle);
            return;
        }

        setTimeout(function() {
            gt_getPlayerVehicle(attempts + 1, maxAttempts, delay, cb);
        }, delay);
    } catch (e) {
        setTimeout(function() {
            gt_getPlayerVehicle(attempts + 1, maxAttempts, delay, cb);
        }, delay);
    }
}

function gt_createVehicle(hash, position, sync) {
    try {
        if (!natives.isModelInCdimage(hash)) {
            gt_showMessage('Model ' + hash + ' not in CD image');
            return null;
        }

        natives.requestModel(hash);
        natives.loadAllObjectsNow();

        var veh = natives.createCar(hash, position, sync);
        if (!veh) {
            gt_showMessage('Failed to spawn model ' + hash);
            return null;
        }

        // Spawn protection
        if (gt_spawnProtectionOn) {
            try {
                natives.setCarCanBeDamaged(veh, false);
                gt_showMessage('Spawn protection for 10 seconds');

                if (gt_spawnProtectionTimer) {
                    clearTimeout(gt_spawnProtectionTimer);
                    gt_spawnProtectionTimer = null;
                }

                gt_spawnProtectionTimer = setTimeout(function() {
                    try {
                        if (natives.doesVehicleExist(veh)) {
                            natives.setCarCanBeDamaged(veh, !gt_vehicleGodMode);
                            gt_showMessage('Spawn protection expired');
                        }
                    } catch (e) {} finally {
                        gt_spawnProtectionTimer = null;
                    }
                }, 10000);
            } catch (e) {
                gt_showMessage('Spawn protection error');
            }
        } else if (gt_vehicleGodMode) {
            try {
                natives.setCarCanBeDamaged(veh, false);
            } catch (e) {}
        }

        return veh;
    } catch (e) {
        gt_showMessage('Vehicle spawn failed: ' + e.message);
        return null;
    }
}

function gt_saveLocation(name) {
    if (!localPlayer || !localPlayer.position) {
        gt_showMessage('No player position');
        return;
    }
    var p = localPlayer.position;
    gt_savedLocations.push({
        name: name,
        pos: new Vec3(p.x, p.y, p.z)
    });
    gt_showMessage('Saved: ' + name);
}

function gt_applyWorldSettings() {
    try {
        // Time freeze / set time
        if (!gt_timeFrozen) {
            // Set the time once when changed; your environment may differ
            natives.setTimeOfDay(gt_timeOfDay); // Example native; adjust if needed
        }

        // Cops
        natives.setMaxWantedLevel(gt_disableCops ? 0 : 6);
    } catch (e) {}
}

