function gt_buildTeleportTab() {
    var locDropdown;

    try {
        gt_window.button(20, 110, 150, 25, 'Teleport to Waypoint', {}, function() {
            try {
                var blipId = natives.getFirstBlipInfoId(8);
                if (!blipId) {
                    gt_showMessage('No waypoint set');
                    return;
                }
                var wp = natives.getBlipCoords(blipId);
                if (!wp || isNaN(wp.x) || isNaN(wp.y) || isNaN(wp.z)) {
                    gt_showMessage('Invalid waypoint');
                    return;
                }
                if (localPlayer.vehicle) {
                    localPlayer.vehicle.position = wp;
                } else {
                    localPlayer.position = wp;
                }
                gt_showMessage('Teleported to waypoint');
            } catch (e) {
                gt_showMessage('Teleport error');
            }
        });
    } catch (e) {}

    try {
        locDropdown = gt_window.dropDown(20, 150, 220, 25, 'Saved Locations', {}, function() {
            var idx = this.selectedEntryIndex;
            if (idx < 0 || idx >= gt_savedLocations.length) return;
            var loc = gt_savedLocations[idx];
            try {
                if (localPlayer.vehicle) {
                    localPlayer.vehicle.position = loc.pos;
                } else {
                    localPlayer.position = loc.pos;
                }
                gt_showMessage('Teleported to ' + loc.name);
            } catch (e) {
                gt_showMessage('Teleport error');
            }
        });

        // Initial fill
        for (var i = 0; i < gt_savedLocations.length; i++) {
            locDropdown.item(gt_savedLocations[i].name);
        }
    } catch (e) {}

    try {
        gt_window.button(260, 150, 100, 25, 'Save Here', {}, function() {
            var name = 'Location ' + (gt_savedLocations.length + 1);
            gt_saveLocation(name);
            try {
                locDropdown.clearItems();
                for (var i = 0; i < gt_savedLocations.length; i++) {
                    locDropdown.item(gt_savedLocations[i].name);
                }
            } catch (e) {}
        });

        gt_window.button(370, 150, 100, 25, 'Delete Last', {}, function() {
            if (gt_savedLocations.length === 0) return;
            var removed = gt_savedLocations.pop();
            gt_showMessage('Removed: ' + removed.name);
            try {
                locDropdown.clearItems();
                for (var i = 0; i < gt_savedLocations.length; i++) {
                    locDropdown.item(gt_savedLocations[i].name);
                }
            } catch (e) {}
        });
    } catch (e) {}
}

