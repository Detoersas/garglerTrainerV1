function gt_startWatchdog() {
    if (gt_weaponCheckTimer) return;

    gt_weaponCheckTimer = setInterval(function() {
        try {
            if (!localPlayer) return;

            // Player God Mode (extra safety)
            if (gt_playerGodMode) {
                natives.setCharInvincible(localPlayer, true);
            }

            // Infinite ammo / no reload – exact implementation depends on your natives
            if (gt_infiniteAmmo || gt_noReload) {
                // Example: keep ammo topped up
                var weaponTypes = [22, 28, 30, 31, 32, 33, 34];
                for (var i = 0; i < weaponTypes.length; i++) {
                    natives.setCharAmmo(localPlayer, weaponTypes[i], 9999);
                }
            }

            // Vehicle God Mode: keep car invincible
            if (gt_vehicleGodMode && localPlayer.vehicle) {
                natives.setCarCanBeDamaged(localPlayer.vehicle, false);
            }
        } catch (e) {}
    }, 200);
}

// ==========================
//      INIT & KEYBIND
// ==========================

garglerTrainerV1.init = function() {
    function tryInit(attempts, maxAttempts, delay) {
        if (attempts > maxAttempts) {
            gt_showMessage('garglerTrainerV1: failed to init (mexui missing)');
            return;
        }

        if (typeof mexui === 'undefined' || !mexui || typeof toColour === 'undefined') {
            setTimeout(function() {
                tryInit(attempts + 1, maxAttempts, delay);
            }, delay);
            return;
        }

        // Detect Free Mode if available (same logic style as your old script)
        try {
            if (typeof gta !== 'undefined' && typeof gta.ivGamemode !== 'undefined') {
                var gm = gta.ivGamemode;
                gt_isFreeMode = (gm === 16 || gm === '16');
                gt_showMessage('Free Mode: ' + (gt_isFreeMode ? 'Yes' : 'No') + ' (GM: ' + gm + ')');
            } else {
                throw new Error('ivGamemode not defined');
            }
        } catch (e) {
            gt_isFreeMode = false;
            gt_showMessage('Gamemode unknown; trainer may be limited');
        }

        // Build UI window
        gt_buildWindow();

        // Bind F3 to toggle
        try {
            bindKey(SDLK_F3, KEYSTATE_DOWN, function() {
                if (!localPlayer) {
                    gt_showMessage('No local player');
                    return;
                }
                if (!gt_window) {
                    gt_buildWindow();
                }
                var show = !gt_window.isShown();
                mexui.setInput(show);
                gt_window.setShown(show);
                if (show) gt_window.center();
            });
        } catch (e) {
            gt_showMessage('Failed to bind F3');
        }

        // Start watchdog
        gt_startWatchdog();

        gt_showMessage('garglerTrainerV1 loaded – press F3 to open');
    }

    tryInit(1, 10, 500);
};

garglerTrainerV1.init();
