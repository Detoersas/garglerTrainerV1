function gt_buildVehiclesTab() {
    // Vehicle spawner dropdown
    var dropdown;
    try {
        dropdown = gt_window.dropDown(20, 110, 220, 25, 'Spawn Vehicle', {}, function() {
            var idx = this.selectedEntryIndex;
            if (idx < 0 || idx >= gt_vehicleModels.length) return;

            var model = gt_vehicleModels[idx];
            var pos   = gt_getPosInFrontOfPlayer(8.0);
            if (!pos) return;

            try {
                if (gt_lastVehicle) {
                    try {
                        destroyElement(gt_lastVehicle);
                        if (gt_spawnProtectionTimer) {
                            clearTimeout(gt_spawnProtectionTimer);
                            gt_spawnProtectionTimer = null;
                        }
                    } catch (e) {}
                    gt_lastVehicle = null;
                }

                var veh = gt_createVehicle(model.id, pos, true);
                if (veh) {
                    natives.setCarHeading(veh, localPlayer.heading);

                    if (natives.isThisModelACar(model.id) ||
                        natives.isThisModelABike(model.id) ||
                        natives.isThisModelAHeli(model.id) ||
                        natives.isThisModelABoat(model.id)) {
                        natives.warpCharIntoCar(localPlayer, veh);
                        gt_showMessage('Spawned: ' + model.name);
                    } else {
                        gt_showMessage('Spawned: ' + model.name + ' (non-drivable)');
                    }

                    gt_lastVehicle = veh;
                }
            } catch (e) {
                gt_showMessage('Spawn error');
            }
        });
        for (var i = 0; i < gt_vehicleModels.length; i++) {
            dropdown.item(gt_vehicleModels[i].name);
        }
    } catch (e) {}

    // Quick vehicle actions: repair, flip, delete
    try {
        gt_window.button(260, 110, 70, 25, 'Repair', {}, function() {
            gt_getPlayerVehicle(1, 5, 200, function(veh) {
                if (!veh) return;
                try {
                    natives.fixCar(veh);
                    gt_showMessage('Vehicle repaired');
                } catch (e) {
                    gt_showMessage('Repair error');
                }
            });
        });

        gt_window.button(335, 110, 70, 25, 'Flip', {}, function() {
            gt_getPlayerVehicle(1, 5, 200, function(veh) {
                if (!veh) return;
                try {
                    if (typeof natives.setCarOnGroundProperly !== 'undefined') {
                        natives.setCarOnGroundProperly(veh);
                    } else {
                        var p = veh.position;
                        natives.setCarHeading(veh, veh.heading);
                        natives.setCarCoordinates(veh, p.x, p.y, p.z + 0.5);
                    }
                    gt_showMessage('Vehicle flipped');
                } catch (e) {
                    gt_showMessage('Flip error');
                }
            });
        });

        gt_window.button(410, 110, 70, 25, 'Delete', {}, function() {
            gt_getPlayerVehicle(1, 5, 200, function(veh) {
                if (!veh) return;
                try {
                    destroyElement(veh);
                    if (veh === gt_lastVehicle) {
                        if (gt_spawnProtectionTimer) {
                            clearTimeout(gt_spawnProtectionTimer);
                            gt_spawnProtectionTimer = null;
                        }
                        gt_lastVehicle = null;
                    }
                    gt_showMessage('Vehicle deleted');
                } catch (e) {
                    gt_showMessage('Delete error');
                }
            });
        });
    } catch (e) {}

    // Toggles row 1: Vehicle God Mode, Spawn Protection, Speed Boost
    try {
        var vgm = gt_window.checkBox(20, 150, 20, 20, '', {}, function() {
            gt_vehicleGodMode = this.checked;
            gt_getPlayerVehicle(1, 5, 200, function(veh) {
                if (!veh) return;
                try {
                    natives.setCarCanBeDamaged(veh, !gt_vehicleGodMode);
                    gt_showMessage('Vehicle God Mode ' + (gt_vehicleGodMode ? 'ON' : 'OFF'));
                } catch (e) {
                    gt_showMessage('Vehicle GM error');
                }
            });
        });
        vgm.checked = gt_vehicleGodMode;
        gt_window.text(45, 150, 130, 20, 'Vehicle God Mode', {});

        var sp = gt_window.checkBox(20, 175, 20, 20, '', {}, function() {
            gt_spawnProtectionOn = this.checked;
            gt_showMessage('Spawn Protection ' + (gt_spawnProtectionOn ? 'ON' : 'OFF'));
        });
        sp.checked = gt_spawnProtectionOn;
        gt_window.text(45, 175, 160, 20, 'Spawn Protection (10s)', {});

        var sb = gt_window.checkBox(20, 200, 20, 20, '', {}, function() {
            gt_speedBoostEnabled = this.checked;
            gt_getPlayerVehicle(1, 5, 200, function(veh) {
                if (!veh) return;
                try {
                    var mult = gt_speedBoostEnabled ? 2.0 : 1.0;
                    // Adjust native name if needed
                    natives.setCarEnginePowerMultiplier(veh, mult);
                    gt_showMessage('Speed Boost ' + (gt_speedBoostEnabled ? 'ON' : 'OFF'));
                } catch (e) {
                    gt_showMessage('Speed Boost error');
                }
            });
        });
        sb.checked = gt_speedBoostEnabled;
        gt_window.text(45, 200, 160, 20, 'Speed Boost', {});
    } catch (e) {}

    // Simple color presets (primary color index examples)
    try {
        gt_window.button(260, 150, 100, 25, 'Color: Sport', {}, function() {
            gt_getPlayerVehicle(1, 5, 200, function(veh) {
                if (!veh) return;
                try {
                    veh.colour1 = 0;  // example color indices
                    veh.colour2 = 1;
                    gt_showMessage('Sport colors set');
                } catch (e) {
                    gt_showMessage('Color error');
                }
            });
        });

        gt_window.button(370, 150, 100, 25, 'Color: Stealth', {}, function() {
            gt_getPlayerVehicle(1, 5, 200, function(veh) {
                if (!veh) return;
                try {
                    veh.colour1 = 6;
                    veh.colour2 = 6;
                    gt_showMessage('Stealth colors set');
                } catch (e) {
                    gt_showMessage('Color error');
                }
            });
        });

        gt_window.button(260, 180, 100, 25, 'Wash Vehicle', {}, function() {
            gt_getPlayerVehicle(1, 5, 200, function(veh) {
                if (!veh) return;
                try {
                    natives.setVehicleDirtLevel(veh, 0);
                    gt_showMessage('Vehicle cleaned');
                } catch (e) {
                    gt_showMessage('Wash error');
                }
            });
        });
    } catch (e) {}
}

