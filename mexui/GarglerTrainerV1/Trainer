function gt_buildWindow() {
    if (!mexui || typeof toColour === 'undefined') {
        gt_showMessage('mexui or toColour not available');
        return;
    }

    try {
        // Close previous window if exists
        if (gt_window && gt_window.isShown()) {
            gt_window.setShown(false);
        }
    } catch (e) {}

    // Main style: darker, cleaner look
    var styles = {
        main: {
            titleBarColour:  toColour(20, 20, 20, 240),
            backgroundColour: toColour(15, 15, 15, 230),
            textColour:      toColour(230, 230, 230, 255),
            hover: {
                backgroundColour: toColour(40, 80, 160, 220),
                transitionTime: 200
            }
        }
    };

    try {
        gt_window = mexui.window(450, 150, 500, 430, 'garglerTrainerV1', styles);
        gt_window.setShown(false);
        gt_window.center();
    } catch (e) {
        gt_showMessage('Error creating garglerTrainerV1 window');
        return;
    }

    // Header: title + credits
    try {
        gt_window.text(10, 5, 480, 22, 'garglerTrainerV1', { align: 'center', textColour: toColour(120, 180, 255, 255) });
        gt_window.text(10, 25, 480, 18, 'Made by Dexter – based on work by SirCryptic & GTA modding community', { align: 'center', textColour: toColour(180, 180, 180, 255) });
    } catch (e) {}

    // Tab buttons row
    var tabNames = ['Vehicles', 'Player', 'World', 'Teleport', 'Fun'];
    var tabKeys  = ['vehicles', 'player', 'world', 'teleport', 'fun'];

    for (var i = 0; i < tabNames.length; i++) {
        (function(i) {
            try {
                var x = 10 + (i * 95);
                var tabBtn = gt_window.button(x, 50, 90, 25, tabNames[i], {}, function() {
                    gt_activeTab = tabKeys[i];
                    gt_refreshTab();
                });
            } catch (e) {}
        })(i);
    }

    // Content area hint
    try {
        gt_window.text(10, 80, 480, 18, 'Press F3 to toggle this trainer. Tabs above switch categories.', { align: 'center', textColour: toColour(160, 160, 160, 255) });
    } catch (e) {}

    // Draw initial tab
    gt_refreshTab();
}

// Simple helper to clear main content area by covering with text or re-creating elements.
function gt_clearContentArea() {
    // There is no direct "clear controls" in some mexui builds, so this is a conceptual space:
    // - Place new controls below y = 105 always
    // - Old controls remain, but you can visually override by placing new ones on top or reuse same positions.
    // If your mexui has a way to remove controls, use that instead.
}

function gt_refreshTab() {
    if (!gt_window) return;

    gt_clearContentArea();

    if (gt_activeTab === 'vehicles') {
        gt_buildVehiclesTab();
    } else if (gt_activeTab === 'player') {
        gt_buildPlayerTab();
    } else if (gt_activeTab === 'world') {
        gt_buildWorldTab();
    } else if (gt_activeTab === 'teleport') {
        gt_buildTeleportTab();
    } else if (gt_activeTab === 'fun') {
        gt_buildFunTab();
    }
}

